# ─── KALSS API — Environment Variables ─────────────────────────────────────
# Salin file ini jadi .env.local untuk development lokal
# Di Vercel: Settings → Environment Variables → Add

# WAJIB: API Keys yang boleh akses KALSS API (pisah dengan koma)
VALID_API_KEYS=kalss_xK9mL2pQrT5vY8nA,kalss_GANTI_INI

# AI — Groq (gratis & cepat) → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# AI — OpenAI (alternatif) → https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Search YouTube → https://console.cloud.google.com
YOUTUBE_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxx

# Search Google Custom Search → https://programmablesearchengine.google.com
GOOGLE_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxx

# Downloader Instagram (RapidAPI) → https://rapidapi.com
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxx
